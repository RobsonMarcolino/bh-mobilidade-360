generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  avatarUrl     String?
  points        Int           @default(0)
  badges        Badge[]
  reports       Report[]
  ratings       Rating[]
  chatSessions  ChatSession[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Report {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  type            ReportType
  severity        Severity
  description     String
  aiDescription   String?
  aiConfidence    Float?
  latitude        Float
  longitude       Float
  address         String
  regional        Regional
  bairro          String
  photos          Photo[]
  status          ReportStatus @default(ABERTO)
  protocol        String       @unique
  responsibleOrg  String?
  estimatedDays   Int?
  resolvedAt      DateTime?
  upvotes         Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([regional])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Photo {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())
}

model Rating {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  lineCode     String
  lineName     String
  lotacao      Int
  pontualidade Int
  limpeza      Int
  conforto     Int
  comment      String?
  createdAt    DateTime @default(now())

  @@index([lineCode])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())
}

model Badge {
  id       String    @id @default(cuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  type     BadgeType
  earnedAt DateTime  @default(now())

  @@unique([userId, type])
}

enum ReportType {
  BURACO
  POSTE_APAGADO
  LIXO_IRREGULAR
  ALAGAMENTO
  SEMAFORO_QUEBRADO
  CALCADA_DANIFICADA
  ARVORE_CAIDA
  ESGOTO_ABERTO
  OUTRO
}

enum Severity {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum ReportStatus {
  ABERTO
  EM_ANALISE
  EM_EXECUCAO
  CONCLUIDO
  CANCELADO
}

enum Regional {
  BARREIRO
  CENTRO_SUL
  LESTE
  NORDESTE
  NOROESTE
  NORTE
  OESTE
  PAMPULHA
  VENDA_NOVA
}

enum MessageRole {
  USER
  ASSISTANT
}

enum BadgeType {
  FISCAL_DO_BAIRRO
  GUARDIAO_DA_RUA
  OLHO_VIVO
  CIDADAO_EXEMPLAR
  HEROI_URBANO
}
