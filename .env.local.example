# ============================================
# BH Mobilidade 360 - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha

# Google Gemini API (gratuita)
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_aqui

# Supabase (gratuito)
# Obtenha em: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://seuproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:senha@db.seuproject.supabase.co:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BH Mobilidade 360
